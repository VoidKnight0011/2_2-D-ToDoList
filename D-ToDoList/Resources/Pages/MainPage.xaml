<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="D_ToDoList.MainPage"
             xmlns:control="clr-namespace:Syncfusion.Maui.ProgressBar;assembly=Syncfusion.Maui.ProgressBar">
    
    <AbsoluteLayout>
        <Grid AbsoluteLayout.LayoutBounds="0,0,1,1"
              AbsoluteLayout.LayoutFlags="All"
              RowDefinitions="auto, auto, auto, *, auto"
              BackgroundColor="{AppThemeBinding Light={StaticResource SurfacePrimary}, Dark={StaticResource SurfacePrimaryDark}}">

            <!-- Header -->
            <Border x:Name="B1" Grid.Row="0" BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceSecondary}, Dark={StaticResource SurfaceSecondaryDark}}" Padding="10" Margin="0, 0, 0, 5">
                <Grid ColumnDefinitions="auto,*">
                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Start">
                        <Label Text="ToDoList" FontSize="Title" FontFamily="PoppinsBlack" TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                        <Label Text="{Binding dateToday}" Margin="0, -15, 0, 0" CharacterSpacing="-1" FontSize="Micro" FontFamily="PoppinsRegular" TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextMutedDark}}" />
                    </VerticalStackLayout>
                    <HorizontalStackLayout Grid.Column="1" HorizontalOptions="End">
                        <VerticalStackLayout Margin="5" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label FontFamily="PoppinsBold" Text="Welcome Back," FontSize="9" TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" Margin="0" />
                            <Label FontFamily="PoppinsRegular" Text="{Binding DisplayName}" FontSize="8" TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" Margin="0" />
                        </VerticalStackLayout>
                        <ImageButton Clicked="LogOut" Source="icon_logout.png" HeightRequest="35" WidthRequest="35" Margin="5" CornerRadius="10" Padding="0" />
                    </HorizontalStackLayout>
                </Grid>
            </Border>

            <!-- Add Task -->
            <Border x:Name="B2" Grid.Row="1" BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceTertiary}, Dark={StaticResource SurfaceTertiaryDark}}" StrokeShape="RoundRectangle 12" Padding="8" Margin="10, 5">
                <Grid ColumnDefinitions="*, 30">
                    <Entry x:Name="taskTitle" Grid.Column="0" Placeholder="What to do for today?" BackgroundColor="Transparent" Margin="10, 5, 10, 5" />
                    <Button Grid.Column="1" ImageSource="icon_add.png" HeightRequest="30" WidthRequest="30" Margin="5, 5, 20, 5" Padding="3" FontFamily="PoppinsRegular" BackgroundColor="{AppThemeBinding Light={StaticResource SurfacePrimaryDark}, Dark={StaticResource SurfacePrimary}}" Clicked="TaskAdd" />
                </Grid>
            </Border>

            <!-- Task Category -->
            <Border x:Name="B3" Grid.Row="2" BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceTertiary}, Dark={StaticResource SurfaceTertiaryDark}}" StrokeShape="RoundRectangle 6" Padding="4" Margin="10, 5">
                <Grid ColumnDefinitions="auto, *, *, *">
                    <Image Source="icon_filter.png" Grid.Column="0" HeightRequest="25" WidthRequest="25" Margin="6, 5, 4, 5" />
                    <Button Grid.Column="1" Text="All" Clicked="FilterAll" TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" Margin="4, 5" />
                    <Button Grid.Column="2" Text="Active" Clicked="FilterActive" TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" Margin="4, 5" />
                    <Button Grid.Column="3" Text="Done" Clicked="FilterDone" TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" Margin="4, 5, 6, 5" />
                </Grid>
            </Border>

            <!-- Task List -->
            <Border x:Name="B4" Grid.Row="3" BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceTertiary}, Dark={StaticResource SurfaceTertiaryDark}}" StrokeShape="RoundRectangle 10" Padding="8" Margin="10, 5, 10, 12">
                <ListView x:Name="ToDoList" ItemsSource="{Binding filtered}" HasUnevenRows="True" SeparatorVisibility="None" SelectionMode="None" BackgroundColor="Transparent">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <ViewCell>
                                <Border Margin="3" StrokeThickness="0">
                                    <Grid ColumnDefinitions="24, *, 36, 36">
                                        <Button Grid.Column="0" BackgroundColor="{Binding checkColor}" BorderWidth="5" BorderColor="{StaticResource AccentPrimary}" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center" CornerRadius="12" Margin="5, 0" Clicked="TaskCheck" CommandParameter="{Binding .}" />
                                        <Label Text="{Binding taskTitle}" LineBreakMode="TailTruncation" VerticalOptions="Center" TextDecorations="{Binding labelDecor}" Grid.Column="1" IsVisible="{Binding isntEditing}" BackgroundColor="Transparent" Margin="5, 10" />
                                        <Button ImageSource="icon_edit.png" BackgroundColor="Transparent" Grid.Column="2" Clicked="TaskEdit" CommandParameter="{Binding .}" HeightRequest="36" WidthRequest="36" HorizontalOptions="Center" Padding="5" CornerRadius="18" Margin="5, 10" />
                                        <Button ImageSource="icon_delete.png" BackgroundColor="Transparent" Grid.Column="3" Clicked="TaskDelete" CommandParameter="{Binding .}" HeightRequest="36" WidthRequest="36" HorizontalOptions="Center" Padding="5" CornerRadius="18" Margin="5, 10" />
                                    </Grid>
                                </Border>
                            </ViewCell>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
            
            <Grid Grid.Row="4">
                <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceSecondary}, Dark={StaticResource SurfaceSecondaryDark}}">
                    <Grid ColumnDefinitions="*, *, *" Padding="0, 10">
                        <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                            <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 14" StrokeThickness="0" HeightRequest="48" WidthRequest="48" HorizontalOptions="Center">
                                <Image Source="icon_tasks.png" HeightRequest="25" WidthRequest="25" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Text="Tasks" TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" HorizontalTextAlignment="Center" FontSize="Micro" />
                        </VerticalStackLayout>

                        <BoxView Grid.Column="1" Color="Transparent" />

                        <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                            <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 14" StrokeThickness="0" HeightRequest="48" WidthRequest="48" HorizontalOptions="Center">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="ToProfile" />
                                </Border.GestureRecognizers>
                                <Image Source="icon_user.png" HeightRequest="25" WidthRequest="25" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Text="Profile" TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" HorizontalTextAlignment="Center" FontSize="Micro" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>


                
                <Grid HorizontalOptions="Center" VerticalOptions="Start"
                      HeightRequest="85" WidthRequest="85"
                      Margin="0, -15, 0, 0">
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceSecondary}, Dark={StaticResource SurfaceSecondaryDark}}"
                            StrokeShape="RoundRectangle 50"
                            StrokeThickness="9"
                            Stroke="{AppThemeBinding Light={StaticResource SurfaceSecondary}, Dark={StaticResource SurfaceSecondaryDark}}">
                        <Grid>
                            <control:SfCircularProgressBar
                                Minimum="0" Progress="{Binding taskPercentage}" Maximum="100"
                                BackgroundColor="Transparent"
                                TrackFill="{StaticResource AccentTertiary}"
                                ProgressFill="{StaticResource AccentPrimary}"
                                TrackThickness="10" ProgressThickness="10"
                                AnimationEasing="{x:Static Easing.SinInOut}"
                                AnimationDuration="1000" />
                            <Label Text="{Binding taskPercentage, StringFormat='{0:F0}%'}"
                                   FontSize="Micro" FontFamily="PoppinsRegular"
                                   HorizontalOptions="Center" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

        </Grid>
        
        <Grid x:Name="LoadingOverlay"
              AbsoluteLayout.LayoutBounds="0,0,1,1"
              AbsoluteLayout.LayoutFlags="All"
              IsVisible="False"
              BackgroundColor="{AppThemeBinding Light={StaticResource SurfacePrimary}, Dark={StaticResource SurfacePrimaryDark}}">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                <ActivityIndicator IsRunning="True" Color="{StaticResource AccentPrimary}" HeightRequest="50" WidthRequest="50" />
                <Label Text="Loading..." HorizontalTextAlignment="Center" FontFamily="PoppinsBold"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
            </VerticalStackLayout>
        </Grid>

    </AbsoluteLayout>
</ContentPage>