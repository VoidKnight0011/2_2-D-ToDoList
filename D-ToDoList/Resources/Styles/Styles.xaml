<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfacePrimary}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
    </Style>

    <Style x:Key="LabelSecondary" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style x:Key="LabelMuted" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="LabelTitle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceTertiary}" />
    </Style>

    <Style TargetType="Editor">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceTertiary}" />
    </Style>

    <Style TargetType="Picker">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="TitleColor" Value="{StaticResource TextMuted}" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceTertiary}" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource AccentPrimary}" />
        <Setter Property="TextColor" Value="{StaticResource TextOnAccent}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style x:Key="ButtonSecondary" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource AccentSubtle}" />
        <Setter Property="TextColor" Value="{StaticResource AccentPrimary}" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="ButtonDanger" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Danger}" />
        <Setter Property="TextColor" Value="{StaticResource TextOnAccent}" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="ButtonGhost" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource AccentPrimary}" />
    </Style>

    <Style x:Key="ButtonDisabled" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Disabled}" />
        <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="Card" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceSecondary}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 10" />
        <Setter Property="Stroke" Value="{StaticResource BorderPrimary}" />
        <Setter Property="Padding" Value="15" />
    </Style>

    <Style x:Key="CardElevated" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceElevated}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="Stroke" Value="{StaticResource BorderSubtle}" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <Style TargetType="ListView">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfacePrimary}" />
        <Setter Property="SeparatorColor" Value="{StaticResource BorderSubtle}" />
    </Style>

</ResourceDictionary>